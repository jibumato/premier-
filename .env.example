# ---- Supabase (Auth + DB) ----
# プロジェクト作成後、Supabase ダッシュボード → Project Settings → API から取得。
# NEXT_PUBLIC_* はブラウザに露出する公開値（anon key は RLS 前提で公開して良い）。
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバー専用（絶対にクライアントへ出さない）。管理系・Webhook 検証などで使用。
# 本番では Cloudflare Workers のプロジェクト環境変数（暗号化）に設定する。
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Cloudflare R2 (画像・Phase 2) ----
# バケット本体へのアクセスは wrangler.toml の R2 バインディング `MEDIA` 経由
# （src/app/api/upload/route.ts）。アクセスキーは不要。
# アップロード画像の公開配信 URL のベース（R2 のパブリックアクセス or カスタムドメイン）。
# 未設定の場合、アップロードは成功するが画像URLは返らない（key のみ）。
NEXT_PUBLIC_R2_PUBLIC_URL=https://images.example.com

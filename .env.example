# ---- Supabase (Auth + DB) ----
# プロジェクト作成後、Supabase ダッシュボード → Project Settings → API から取得。
# NEXT_PUBLIC_* はブラウザに露出する公開値（anon key は RLS 前提で公開して良い）。
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバー専用（絶対にクライアントへ出さない）。管理系・Webhook 検証などで使用。
# 本番では Cloudflare Pages のプロジェクト環境変数（暗号化）に設定する。
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Cloudflare R2 (画像・Phase 2 で本格利用) ----
# R2 は Worker/Functions からバインディング経由でアクセスするのが基本。
# CLI/外部から使う場合のみ以下の S3 互換キーを利用（.dev.vars 側に置く）。
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=premier-images
# NEXT_PUBLIC_R2_PUBLIC_URL=https://images.example.com
